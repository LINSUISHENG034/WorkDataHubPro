# Default repository line ending policy
* text=auto eol=lf

# Windows-native script files
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Common binary assets for ETL references and artifacts
*.gif binary
*.jpg binary
*.jpeg binary
*.parquet binary
*.pdf binary
*.png binary
*.xls binary
*.xlsm binary
*.xlsx binary
*.zip binary
